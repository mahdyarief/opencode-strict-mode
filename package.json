{
  "name": "opencode-strict-mode",
  "version": "1.0.0",
  "description": "OpenCode plugin that enables strict-mode responses globally by default.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "sideEffects": false,
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SKILL.md",
    "scripts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node --test"
  },
  "keywords": [
    "opencode",
    "plugin",
    "strict-mode",
    "ai",
    "assistant"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/mahdyarief/opencode-strict-mode.git"
  },
  "bugs": {
    "url": "https://github.com/mahdyarief/opencode-strict-mode/issues"
  },
  "homepage": "https://github.com/mahdyarief/opencode-strict-mode#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@opencode-ai/plugin": "^1.4.7"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  }
}
