{
  "name": "opencode-strict-mode",
  "version": "1.0.0",
  "description": "OpenCode plugin that enables strict-mode responses globally by default.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "files": [
    "dist",
    "README.md",
    "CHANGELOG.md",
    "LICENSE",
    "SKILL.md",
    "scripts"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "clean": "node -e \"require('fs').rmSync('dist', { recursive: true, force: true })\"",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "keywords": [
    "opencode",
    "plugin",
    "strict-mode",
    "ai",
    "assistant"
  ],
  "license": "MIT",
  "dependencies": {
    "@opencode-ai/plugin": "^1.4.7"
  },
  "devDependencies": {
    "typescript": "^5.8.2"
  }
}
